{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "baby-food",
  "main": ".open-next/worker.js",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat", "global_fetch_strictly_public"],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "enabled": true
  },
  // Public, non-secret values. Mirrored in .env.production so `next build`
  // can inline them into the client bundle. Server secrets live in .dev.vars
  // (local) and Cloudflare dashboard secrets (prod) — never committed.
  "vars": {
    "NEXT_PUBLIC_SITE_URL": "https://baby-food.brettsschmidt.workers.dev",
    "NEXT_PUBLIC_SUPABASE_URL": "https://yjwoqpukvjeacavsyves.supabase.co",
    "NEXT_PUBLIC_SUPABASE_ANON_KEY": "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Inlqd29xcHVrdmplYWNhdnN5dmVzIiwicm9sZSI6ImFub24iLCJpYXQiOjE3Nzc5MDc1MTUsImV4cCI6MjA5MzQ4MzUxNX0.CljKr9KZTJxr1vpNQGktk2EGzME1J8D3q8m39IVz1ZQ"
  }
}
